<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="999dp"/>
            <gradient android:startColor="@color/zen_ocean_blue" android:endColor="@color/zen_ocean_teal" android:angle="0"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="999dp"/>
            <gradient android:startColor="#CCFFFFFF" android:endColor="#B3FFFFFF" android:angle="0"/>
        </shape>
    </item>
</selector>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minWidth="300dp"
    android:foregroundGravity="center_horizontal"
    style="@style/Widget.ZenSwitch.Card"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_5">

    <!-- Top row: icon circle, title+tag, close -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/icon_wrap"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_soft"
            android:gravity="center"
            android:layout_alignParentStart="true">
            <ImageView
                android:id="@+id/icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_star_badge"
                android:tint="?attr/colorPrimary"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/icon_wrap"
            android:layout_marginStart="10dp"
            android:layout_alignTop="@id/icon_wrap">
            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Steps"
                android:textAppearance="@style/TextAppearance.ZenSwitch.TitleMedium"
                android:textColor="?attr/colorOnSurface"/>
            <TextView
                android:id="@+id/tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="milestone"
                android:textColor="@android:color/white"
                android:textAppearance="@style/TextAppearance.ZenSwitch.LabelMedium"
                android:paddingStart="@dimen/space_3"
                android:paddingEnd="@dimen/space_3"
                android:paddingTop="@dimen/space_1"
                android:paddingBottom="@dimen/space_1"
                android:background="@drawable/bg_pill_green"
                android:layout_marginTop="@dimen/space_2"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:tint="?attr/colorOnSurfaceVariant"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </RelativeLayout>

    <TextView
        android:id="@+id/desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="Complete your first mindful activity"
        android:textAppearance="@style/TextAppearance.ZenSwitch.BodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"/>

    <!-- Unlocked on pill -->
    <LinearLayout
        android:id="@+id/unlocked_pill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_4"
        android:layout_marginTop="@dimen/space_4"
        android:background="@drawable/bg_unlocked_pill">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unlocked on"
            android:textAppearance="@style/TextAppearance.ZenSwitch.LabelLarge"
            android:textAlignment="center"
            android:textColor="?attr/colorPrimary"/>
        <TextView
            android:id="@+id/date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monday, January 15, 2024"
            android:textAlignment="center"
            android:layout_marginTop="@dimen/space_1"
            android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
            android:textColor="?attr/colorOnSurface"/>
    </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_4">

        <!-- Trophy Room header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="88dp"
                android:layout_height="88dp"
                app:cardCornerRadius="@dimen/radius_full"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_star_badge"
                    android:tint="?attr/colorPrimary"
                    android:contentDescription="@null" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/level_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_3"
                android:paddingStart="@dimen/space_4"
                android:paddingEnd="@dimen/space_4"
                android:paddingTop="@dimen/space_2"
                android:paddingBottom="@dimen/space_2"
                android:text="Seedling"
                android:textAppearance="@style/TextAppearance.ZenSwitch.LabelLarge"
                android:textColor="?attr/colorOnSurface"
                android:background="@drawable/bg_small_pill" />

            <TextView
                android:id="@+id/total_points_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:text="240"
                android:textAppearance="@style/TextAppearance.ZenSwitch.DisplayMedium"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total points"
                android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/streak_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:text="Streak: 0"
                android:textAppearance="@style/TextAppearance.ZenSwitch.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Weekly Challenge Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            style="@style/Widget.ZenSwitch.Card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weekly"
                        android:textAppearance="@style/TextAppearance.ZenSwitch.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />
                    <TextView
                        android:id="@+id/weekly_challenge_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:layout_gravity="end"
                        android:text="3/5"
                        android:textAppearance="@style/TextAppearance.ZenSwitch.LabelLarge"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="Complete 5 activities this week"
                    android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <ProgressBar
                    android:id="@+id/weekly_challenge_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="@dimen/space_3"
                    android:max="100"
                    android:progress="60"
                    android:progressDrawable="@drawable/progress_weekly_premium"/>

                <TextView
                    android:id="@+id/weekly_challenge_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25% to next reward"
                    android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingStart="@dimen/space_3"
                    android:paddingEnd="@dimen/space_3"
                    android:paddingTop="@dimen/space_2"
                    android:paddingBottom="@dimen/space_2"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/space_3"
                    android:background="@drawable/bg_small_pill"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Collectibles grid -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            style="@style/Widget.ZenSwitch.Card"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/space_4">

                <TextView
                    android:id="@+id/badges_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Badges"
                    android:textAppearance="@style/TextAppearance.ZenSwitch.TitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/grid_mid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.5" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/badge_first_steps"
                    style="@style/Widget.ZenSwitch.Card"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="@dimen/space_3"
                    android:layout_marginEnd="@dimen/space_2"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/grid_mid"
                    app:layout_constraintTop_toBottomOf="@id/badges_title"
                    app:layout_constraintDimensionRatio="1:1">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/space_4">

                        <ImageView
                            android:id="@+id/badge_first_steps_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_star_badge"
                            android:tint="?attr/colorPrimary"
                            android:contentDescription="@null"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="First Steps"
                            android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:gravity="center"
                            app:layout_constraintTop_toBottomOf="@id/badge_first_steps_icon"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/badge_early_bird"
                    style="@style/Widget.ZenSwitch.Card"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="@dimen/space_3"
                    android:layout_marginStart="@dimen/space_2"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintStart_toStartOf="@id/grid_mid"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/badges_title"
                    app:layout_constraintDimensionRatio="1:1">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/space_4">

                        <ImageView
                            android:id="@+id/badge_early_bird_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_calendar"
                            android:tint="?attr/colorPrimary"
                            android:contentDescription="@null"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="Early Bird"
                            android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:gravity="center"
                            app:layout_constraintTop_toBottomOf="@id/badge_early_bird_icon"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/badge_streak_master"
                    style="@style/Widget.ZenSwitch.Card"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="@dimen/space_3"
                    android:layout_marginEnd="@dimen/space_2"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/grid_mid"
                    app:layout_constraintTop_toBottomOf="@id/badge_first_steps"
                    app:layout_constraintDimensionRatio="1:1">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/space_4">

                        <ImageView
                            android:id="@+id/badge_streak_master_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_bolt"
                            android:tint="?attr/colorPrimary"
                            android:contentDescription="@null"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="Streak Master"
                            android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:gravity="center"
                            app:layout_constraintTop_toBottomOf="@id/badge_streak_master_icon"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/badge_upcoming_activity_explorer"
                    style="@style/Widget.ZenSwitch.Card"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="@dimen/space_3"
                    android:layout_marginStart="@dimen/space_2"
                    android:alpha="0.55"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintStart_toStartOf="@id/grid_mid"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/badge_early_bird"
                    app:layout_constraintDimensionRatio="1:1">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/space_4">

                        <ImageView
                            android:id="@+id/badge_upcoming_activity_explorer_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_target"
                            android:tint="?attr/colorOnSurfaceVariant"
                            android:contentDescription="@null"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="Activity Explorer"
                            android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="center"
                            app:layout_constraintTop_toBottomOf="@id/badge_upcoming_activity_explorer_icon"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/badge_upcoming_monthly_champion"
                    style="@style/Widget.ZenSwitch.Card"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="@dimen/space_3"
                    android:layout_marginEnd="@dimen/space_2"
                    android:alpha="0.55"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/grid_mid"
                    app:layout_constraintTop_toBottomOf="@id/badge_streak_master"
                    app:layout_constraintDimensionRatio="1:1">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/space_4">

                        <ImageView
                            android:id="@+id/badge_upcoming_monthly_champion_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_calendar"
                            android:tint="?attr/colorOnSurfaceVariant"
                            android:contentDescription="@null"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="Monthly Champion"
                            android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="center"
                            app:layout_constraintTop_toBottomOf="@id/badge_upcoming_monthly_champion_icon"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/badge_upcoming_zen_master"
                    style="@style/Widget.ZenSwitch.Card"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="@dimen/space_3"
                    android:layout_marginStart="@dimen/space_2"
                    android:alpha="0.55"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintStart_toStartOf="@id/grid_mid"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/badge_upcoming_activity_explorer"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/space_4">

                        <ImageView
                            android:id="@+id/badge_upcoming_zen_master_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_trophy"
                            android:tint="?attr/colorOnSurfaceVariant"
                            android:contentDescription="@null"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="Zen Master"
                            android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="center"
                            app:layout_constraintTop_toBottomOf="@id/badge_upcoming_zen_master_icon"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Store shelf -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            style="@style/Widget.ZenSwitch.Card"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <TextView
                    android:id="@+id/zen_store_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zen Store"
                    android:textAppearance="@style/TextAppearance.ZenSwitch.TitleMedium"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_1"
                    android:text="Spend points to unlock upgrades"
                    android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.ZenSwitch.Card"
                            android:layout_width="220dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_3"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/space_4">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ocean Breeze"
                                    android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_1"
                                    android:text="500 pts"
                                    android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_buy_ocean"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_3"
                                    android:text="Unlock"
                                    style="@style/Widget.ZenSwitch.Button.Tonal" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.ZenSwitch.Card"
                            android:layout_width="220dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_3"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/space_4">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sunset Serenity"
                                    android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_1"
                                    android:text="500 pts"
                                    android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_buy_sunset"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_3"
                                    android:text="Unlock"
                                    style="@style/Widget.ZenSwitch.Button.Tonal" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.ZenSwitch.Card"
                            android:layout_width="220dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_3"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/space_4">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Minimalist Mist"
                                    android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_1"
                                    android:text="500 pts"
                                    android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_buy_minimal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_3"
                                    android:text="Unlock"
                                    style="@style/Widget.ZenSwitch.Button.Tonal" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.ZenSwitch.Card"
                            android:layout_width="220dp"
                            android:layout_height="wrap_content"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/space_4">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Streak Freeze"
                                    android:textAppearance="@style/TextAppearance.ZenSwitch.TitleSmall"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_1"
                                    android:text="1000 pts"
                                    android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_buy_freeze"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_3"
                                    android:text="Unlock"
                                    style="@style/Widget.ZenSwitch.Button.Tonal" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>


<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:context=".ui.profile.ProfileFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/profile_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="?android:attr/colorBackground">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/profile_collapsing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true"
            app:contentScrim="?attr/colorSurface"
            app:expandedTitleGravity="bottom"
            app:collapsedTitleGravity="center_vertical"
            app:titleEnabled="false"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/profile_toolbar"
                style="@style/Widget.ZenSwitch.TopAppBar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:title=""
                android:background="@android:color/transparent" />

            <ImageButton
                android:id="@+id/btn_open_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/space_2"
                android:layout_marginEnd="@dimen/space_3"
                android:background="@android:color/transparent"
                android:padding="@dimen/space_2"
                android:src="@drawable/ic_settings"
                android:tint="?attr/colorOnSurface"
                android:contentDescription="@null"
                app:layout_collapseMode="pin" />

            <!-- Hero Section -->
            <LinearLayout
                android:id="@+id/hero_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="@dimen/space_4"
                android:paddingEnd="@dimen/space_4"
                android:paddingTop="24dp"
                android:paddingBottom="@dimen/space_2"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.75">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/profile_completeness"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="center"
                        android:indeterminate="false"
                        app:indicatorSize="100dp"
                        app:indicatorInset="0dp"
                        app:trackThickness="5dp"
                        app:trackColor="?attr/colorSurfaceVariant"
                        app:indicatorColor="?attr/colorPrimary" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/avatar_container"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        style="@style/Widget.ZenSwitch.Card"
                        app:cardCornerRadius="999dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="?attr/colorPrimary">

                        <TextView
                            android:id="@+id/avatar_initials"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="AC"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimary"
                            android:textSize="22sp" />

                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="bottom|end"
                            android:layout_marginEnd="2dp"
                            android:layout_marginBottom="2dp"
                            android:background="@drawable/bg_camera_badge">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_camera"
                                android:contentDescription="@null" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>

                <TextView
                    android:id="@+id/name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Alex Chen"
                    android:textAppearance="@style/TextAppearance.ZenSwitch.HeadlineSmall"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="alex@example.com"
                    android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/bio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="One breath at a time"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textStyle="italic"
                    android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_edit_profile"
                    style="@style/Widget.ZenSwitch.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="Edit Profile"
                    app:icon="@drawable/ic_edit"
                    app:iconPadding="6dp" />

            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_4">

            <!-- Strava-Style Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="@dimen/space_4"
                android:paddingBottom="@dimen/space_3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_flame"
                        android:tint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/streak_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Streak: —"
                        android:textAppearance="@style/TextAppearance.ZenSwitch.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Streak"
                        android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_clock"
                        android:tint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/points_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Minutes: 0"
                        android:textAppearance="@style/TextAppearance.ZenSwitch.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Time"
                        android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_bolt"
                        android:tint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/activities_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Level: 0"
                        android:textAppearance="@style/TextAppearance.ZenSwitch.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level"
                        android:textAppearance="@style/TextAppearance.ZenSwitch.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/zen_identity_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true"
                app:strokeWidth="1dp"
                app:strokeColor="#30FFFFFF"
                app:cardBackgroundColor="@android:color/transparent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/zen_identity_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_zen_identity_gradient"
                    android:clipToOutline="true"
                    android:outlineProvider="background"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/zen_identity_avatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_pulse_circle"
                        android:padding="10dp"
                        android:src="@drawable/ic_profile"
                        android:tint="?attr/colorOnPrimary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/zen_identity_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/zen_id_not_set"
                        android:textColor="?attr/colorOnPrimary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:shadowColor="#80000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="2"
                        app:layout_constraintStart_toEndOf="@id/zen_identity_avatar"
                        app:layout_constraintTop_toTopOf="@id/zen_identity_avatar"
                        app:layout_constraintBottom_toBottomOf="@id/zen_identity_avatar"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <LinearLayout
                        android:id="@+id/zen_identity_primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/zen_identity_avatar">

                        <TextView
                            android:id="@+id/zen_identity_archetype_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/zen_id_archetype_label"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:shadowColor="#80000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/zen_identity_archetype_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/zen_id_not_set"
                            android:textColor="?attr/colorOnPrimary"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-medium"
                            android:shadowColor="#80000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/zen_identity_north_star_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/zen_id_north_star_label"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:shadowColor="#80000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/zen_identity_north_star_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/zen_id_not_set"
                            android:textColor="?attr/colorOnPrimary"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-medium"
                            android:shadowColor="#80000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/zen_identity_secondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/zen_identity_primary">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/zen_identity_age_label"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/zen_id_age_label"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:shadowColor="#80000000"
                                    android:shadowDx="1"
                                    android:shadowDy="1"
                                    android:shadowRadius="2" />

                                <TextView
                                    android:id="@+id/zen_identity_age_value"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/zen_id_not_set"
                                    android:textColor="?attr/colorOnPrimary"
                                    android:textSize="14sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:shadowColor="#80000000"
                                    android:shadowDx="1"
                                    android:shadowDy="1"
                                    android:shadowRadius="2" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/zen_identity_gender_label"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/zen_id_gender_label"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:shadowColor="#80000000"
                                    android:shadowDx="1"
                                    android:shadowDy="1"
                                    android:shadowRadius="2" />

                                <TextView
                                    android:id="@+id/zen_identity_gender_value"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/zen_id_not_set"
                                    android:textColor="?attr/colorOnPrimary"
                                    android:textSize="14sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:shadowColor="#80000000"
                                    android:shadowDx="1"
                                    android:shadowDy="1"
                                    android:shadowRadius="2" />

                            </LinearLayout>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/zen_identity_contact_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/zen_id_contact_label"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:shadowColor="#80000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2" />

                        <TextView
                            android:id="@+id/zen_identity_contact_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/zen_id_not_set"
                            android:textColor="?attr/colorOnPrimary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:shadowColor="#80000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="2" />

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
